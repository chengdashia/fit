/* =============================================================
   Profile · Liquid Glass
   ============================================================= */
.profile-page {
  min-height: 100vh;
  padding-bottom: 80rpx;
}

.status-bar { width: 100%; }

.page-header { margin: 24rpx 0 32rpx; }
.profile-title {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.1;
  letter-spacing: -0.5rpx;
}
.profile-subtitle {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  letter-spacing: 0.5rpx;
}

/* —— Hero card —— */
.glass-card {
  position: relative;
  overflow: hidden;
  background: var(--glass-fill-strong);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-xl);
  padding: 36rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-glass);
  backdrop-filter: var(--blur-glass);
  -webkit-backdrop-filter: var(--blur-glass);
}
.glass-card::before {
  content: '';
  position: absolute; top: 0; right: 0; bottom: 60%; left: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.45), transparent);
  pointer-events: none;
}
.glass-card::after {
  content: '';
  position: absolute;
  right: -120rpx; top: -120rpx;
  width: 280rpx; height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139, 109, 255, 0.16) 0%, transparent 70%);
  pointer-events: none;
}
.glass-card > view,
.glass-card > text,
.glass-card > image,
.glass-card > button { position: relative; z-index: 1; }

.hero-card { padding: 40rpx 36rpx; }
.hero-top {
  display: flex;
  align-items: center;
}
.avatar-wrap {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  border-radius: 36rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 28rpx;
  box-shadow:
    0 14rpx 32rpx rgba(79, 108, 255, 0.30),
    inset 0 2rpx 0 rgba(255,255,255,0.45);
  border: 1rpx solid rgba(255,255,255,0.55);
  background: var(--grad-primary);
}
.avatar-img {
  width: 100%;
  height: 100%;
  position: absolute; top: 0; right: 0; bottom: 0; left: 0;
}
.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--grad-primary);
  position: relative;
  overflow: hidden;
}
.avatar-placeholder::before {
  content: '';
  position: absolute; top: 0; right: 0; bottom: 60%; left: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.42), transparent);
  pointer-events: none;
}
.avatar-silhouette {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.92);
  position: relative;
}
.avatar-silhouette::after {
  content: '';
  position: absolute;
  top: 36rpx; left: -22rpx; right: -22rpx; bottom: -28rpx;
  border-radius: 60rpx 60rpx 0 0 / 80rpx 80rpx 0 0;
  background: rgba(255,255,255,0.92);
}

.hero-info { flex: 1; min-width: 0; }
.nickname {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
  margin-bottom: 14rpx;
}
.status-pill {
  display: inline-flex;
  align-items: center;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: var(--primary-light);
  color: var(--accent-blue);
  font-size: 24rpx;
  font-weight: 800;
  border: 1rpx solid rgba(79, 140, 255, 0.14);
}
.status-pill.empty {
  background: rgba(255, 181, 92, 0.14);
  color: #d07a14;
  border-color: rgba(255, 181, 92, 0.22);
}
.status-icon { margin-right: 8rpx; font-size: 26rpx; }
.status-text { letter-spacing: 0.5rpx; }

/* —— 目标三段 stat —— */
.goal-stats {
  display: flex;
  align-items: center;
  margin-top: 36rpx;
  padding: 30rpx 18rpx;
  border-radius: var(--radius-lg);
  background: var(--glass-fill-soft);
  border: 1rpx solid var(--glass-border);
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
  position: relative;
  overflow: hidden;
}
.goal-stats::before {
  content: '';
  position: absolute; top: 0; right: 0; bottom: 60%; left: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.40), transparent);
  pointer-events: none;
}
.goal-stats > view,
.goal-stats > text { position: relative; z-index: 1; }

.stat-item { flex: 1; min-width: 0; text-align: center; }
.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}
.stat-value-row { display: flex; align-items: baseline; justify-content: center; }
.stat-value {
  font-size: 36rpx;
  font-weight: 800;
  background: var(--grad-primary);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: -0.5rpx;
}
.stat-unit {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-left: 4rpx;
}
.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(111, 136, 181, 0.16);
}

/* —— Body stat —— */
.body-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
}
.body-stat {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.body-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 28rpx;
  background: var(--grad-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 10rpx 24rpx rgba(79, 108, 255, 0.28),
              inset 0 2rpx 0 rgba(255,255,255,0.45);
  border: 1rpx solid rgba(255,255,255,0.55);
  position: relative;
  overflow: hidden;
}
.body-icon::before {
  content: '';
  position: absolute; top: 0; right: 0; bottom: 60%; left: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.40), transparent);
  pointer-events: none;
}
.weight-icon { background: linear-gradient(135deg, var(--accent-amber) 0%, #ff7a3d 100%); }
.height-icon { background: linear-gradient(135deg, var(--accent-mint) 0%, var(--accent-blue) 100%); }
.body-icon-text { font-size: 36rpx; }
.body-meta { display: flex; flex-direction: column; min-width: 0; }
.body-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}
.body-value {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary);
}
.body-split {
  width: 1rpx;
  height: 70rpx;
  background: rgba(111, 136, 181, 0.16);
  margin: 0 24rpx;
}

/* —— Menu —— */
.menu-card { padding: 12rpx 32rpx; }
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(111, 136, 181, 0.10);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { transform: scale(0.98); }
.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--glass-fill-soft);
  border: 1rpx solid var(--glass-border);
  margin-right: 24rpx;
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
  overflow: hidden;
  flex-shrink: 0;
}
.menu-icon-img { width: 40rpx; height: 40rpx; }
.goal-icon   { background: linear-gradient(135deg, rgba(79,140,255,0.18), rgba(255,255,255,0.85)); }
.diet-icon   { background: linear-gradient(135deg, rgba(43,182,115,0.18), rgba(255,255,255,0.85)); }
.train-icon  { background: linear-gradient(135deg, rgba(139,109,255,0.18), rgba(255,255,255,0.85)); }
.about-icon  { background: linear-gradient(135deg, rgba(255,181,92,0.22), rgba(255,255,255,0.85)); }
.logout-icon { background: linear-gradient(135deg, rgba(239,79,90,0.16), rgba(255,255,255,0.85)); }

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 700;
}
.menu-arrow {
  color: var(--text-tertiary);
  font-size: 40rpx;
  font-weight: 200;
  line-height: 1;
}
.menu-item.logout .menu-text { color: var(--danger); }

/* —— Footer —— */
.footer-quote {
  text-align: center;
  margin-top: 48rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.quote-heart {
  color: var(--accent-rose);
  font-size: 32rpx;
  margin-right: 8rpx;
}
.quote-text { letter-spacing: 0.5rpx; }

/* —— about modal —— */
.modal-mask {
  position: fixed;
  top: 0; right: 0; bottom: 0; left: 0;
  background: rgba(17, 24, 39, 0.42);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 32rpx;
  box-sizing: border-box;
}
.modal-box {
  width: 100%;
  max-width: 580rpx;
  background: var(--glass-fill-strong);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-xl);
  padding: 40rpx;
  box-shadow: var(--shadow-glass-hover);
  backdrop-filter: var(--blur-glass-lg);
  -webkit-backdrop-filter: var(--blur-glass-lg);
  position: relative;
  overflow: hidden;
}
.modal-box::before {
  content: '';
  position: absolute; top: 0; right: 0; bottom: 60%; left: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.50), transparent);
  pointer-events: none;
}
.modal-box > view,
.modal-box > text,
.modal-box > image,
.modal-box > button { position: relative; z-index: 1; }
.modal-title {
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
  margin-bottom: 20rpx;
  color: var(--text-primary);
}
.modal-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 28rpx;
  text-align: center;
}
.modal-actions {
  display: flex;
  gap: 20rpx;
}
.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  background: var(--grad-primary);
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.55);
  box-shadow: var(--shadow-glass-hover);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.modal-btn:active { transform: scale(0.97); }