.profile-page {
  min-height: 100vh;
  background: linear-gradient(165deg, #f8fbff 0%, #eaf3ff 38%, #f5f9ff 68%, #eef4ff 100%);
  position: relative;
  overflow: hidden;
}

.profile-page::before,
.profile-page::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.profile-page::before {
  width: 420rpx;
  height: 420rpx;
  top: -80rpx;
  right: -120rpx;
  background: radial-gradient(circle, rgba(102, 166, 255, 0.28) 0%, rgba(102, 166, 255, 0) 70%);
}

.profile-page::after {
  width: 360rpx;
  height: 360rpx;
  bottom: 180rpx;
  left: -100rpx;
  background: radial-gradient(circle, rgba(124, 92, 255, 0.16) 0%, rgba(124, 92, 255, 0) 70%);
}

.profile-page .container {
  position: relative;
  z-index: 1;
  padding: 0 32rpx calc(48rpx + env(safe-area-inset-bottom));
}

.page-header {
  padding: 12rpx 0 28rpx;
}

.profile-title {
  font-size: 56rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1.15;
  letter-spacing: -1rpx;
}

.profile-subtitle {
  margin-top: 12rpx;
  color: #667085;
  font-size: 28rpx;
  line-height: 1.5;
}

.glass-card {
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 36rpx;
  box-shadow:
    0 18rpx 56rpx rgba(47, 111, 246, 0.10),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}

.hero-card {
  padding: 36rpx 32rpx 28rpx;
  margin-bottom: 24rpx;
}

.hero-top {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-wrap {
  flex-shrink: 0;
  width: 128rpx;
  height: 128rpx;
  margin-right: 24rpx;
}

.avatar-img,
.avatar-placeholder {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 14rpx 36rpx rgba(47, 111, 246, 0.18);
}

.avatar-placeholder {
  background: radial-gradient(circle at 35% 28%, #8bd3ff 0%, #2f6ff6 52%, #7c5cff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-silhouette {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50% 50% 42% 42%;
  background: rgba(255, 255, 255, 0.88);
  position: relative;
}

.avatar-silhouette::before {
  content: '';
  position: absolute;
  top: -22rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.88);
}

.hero-info {
  flex: 1;
  min-width: 0;
}

.nickname {
  font-size: 44rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1.2;
  margin-bottom: 14rpx;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(47, 111, 246, 0.10);
  border: 1rpx solid rgba(47, 111, 246, 0.12);
}

.status-pill.empty {
  background: rgba(152, 162, 179, 0.10);
  border-color: rgba(152, 162, 179, 0.16);
}

.status-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #2f6ff6;
}

.status-pill.empty .status-text {
  color: #667085;
}

.goal-stats {
  display: flex;
  align-items: stretch;
  padding: 28rpx 8rpx 8rpx;
  border-top: 1rpx solid rgba(111, 136, 181, 0.12);
}

.stat-item {
  flex: 1;
  text-align: center;
  min-width: 0;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #667085;
  line-height: 1.35;
  margin-bottom: 12rpx;
}

.stat-value-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #2f6ff6;
  line-height: 1;
}

.stat-unit {
  font-size: 22rpx;
  color: #98a2b3;
  font-weight: 500;
}

.stat-divider {
  width: 1rpx;
  background: rgba(111, 136, 181, 0.16);
  margin: 4rpx 0;
}

.body-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
}

.body-stat {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.body-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.weight-icon,
.height-icon {
  background: rgba(47, 111, 246, 0.10);
}

.body-icon-text {
  font-size: 34rpx;
  line-height: 1;
}

.body-meta {
  min-width: 0;
}

.body-label {
  display: block;
  font-size: 24rpx;
  color: #667085;
  margin-bottom: 8rpx;
}

.body-value {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1.2;
}

.body-split {
  width: 1rpx;
  height: 72rpx;
  background: rgba(111, 136, 181, 0.16);
  margin: 0 12rpx;
  flex-shrink: 0;
}

.menu-card {
  overflow: hidden;
  margin-bottom: 36rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  padding: 0 28rpx;
  border-bottom: 1rpx solid rgba(111, 136, 181, 0.12);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.45);
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  background: rgba(47, 111, 246, 0.10);
  flex-shrink: 0;
}

.menu-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.menu-arrow {
  font-size: 36rpx;
  color: #c7cdd8;
  font-weight: 300;
  line-height: 1;
}

.menu-item.logout .menu-text {
  color: #ef4444;
}

.menu-item.logout .menu-icon {
  background: rgba(239, 68, 68, 0.08);
}

.footer-quote {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 8rpx 0 24rpx;
}

.quote-heart {
  font-size: 24rpx;
  color: #98a2b3;
}

.quote-text {
  font-size: 24rpx;
  color: #98a2b3;
  line-height: 1.5;
}
