/* =============================================================
   Diet Record · Liquid Glass
   ============================================================= */
.page-title {
  margin-top: 36rpx;
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.1;
  letter-spacing: -0.5rpx;
}
.page-subtitle {
  margin: 14rpx 0 36rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* —— Meal tabs (4 chip) —— */
.meal-tabs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-bottom: 32rpx;
}
.tab {
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 999rpx;
  background: var(--glass-fill-soft);
  border: 1rpx solid var(--glass-border);
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 700;
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
  box-shadow: 0 6rpx 20rpx rgba(47, 80, 160, 0.06);
  transition: transform .18s cubic-bezier(.2,.8,.2,1),
              background .25s ease, color .25s ease;
}
.tab:active { transform: scale(0.96); }
.tab.active {
  color: #fff;
  font-weight: 800;
  background: var(--grad-primary);
  border-color: rgba(255,255,255,0.6);
  box-shadow: 0 14rpx 32rpx rgba(79, 108, 255, 0.34);
}

/* —— Summary 卡 —— */
.summary-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 32rpx;
  padding: 36rpx 30rpx;
  border-radius: var(--radius-xl);
  background: var(--glass-fill-strong);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-glass);
  backdrop-filter: var(--blur-glass);
  -webkit-backdrop-filter: var(--blur-glass);
  display: flex;
  align-items: center;
}
.summary-card::before {
  content: '';
  position: absolute; top: 0; right: 0; bottom: 50%; left: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.45), transparent);
  pointer-events: none;
}
.summary-card::after {
  content: '';
  position: absolute;
  right: -100rpx; top: -100rpx;
  width: 240rpx; height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139, 109, 255, 0.18) 0%, transparent 70%);
  pointer-events: none;
}
.summary-card > view,
.summary-card > text { position: relative; z-index: 1; }

.summary-item { flex: 1; }
.summary-label {
  color: var(--text-secondary);
  font-size: 26rpx;
  margin-bottom: 16rpx;
  font-weight: 600;
}
.summary-value {
  color: var(--accent-blue);
  font-size: 62rpx;
  font-weight: 800;
  line-height: 1;
}
.summary-unit {
  margin-left: 8rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  font-weight: 500;
}
.summary-sub {
  margin-top: 16rpx;
  color: var(--text-tertiary);
  font-size: 24rpx;
}
.summary-divider {
  width: 1rpx;
  height: 130rpx;
  background: rgba(111, 136, 181, 0.16);
  margin: 0 28rpx;
}

/* —— Options grid (4 tile) —— */
.options-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
  margin-bottom: 36rpx;
}
.option-card {
  position: relative;
  overflow: hidden;
  min-height: 240rpx;
  padding: 36rpx 30rpx;
  border-radius: var(--radius-xl);
  background: var(--glass-fill-strong);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-glass);
  backdrop-filter: var(--blur-glass);
  -webkit-backdrop-filter: var(--blur-glass);
  box-sizing: border-box;
  transition: transform .18s cubic-bezier(.2,.8,.2,1),
              box-shadow .18s ease;
}
.option-card::before {
  content: '';
  position: absolute; top: 0; right: 0; bottom: 60%; left: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.45), transparent);
  pointer-events: none;
}
.option-card::after {
  content: '';
  position: absolute;
  right: -70rpx; bottom: -70rpx;
  width: 180rpx; height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79, 140, 255, 0.10) 0%, transparent 70%);
  pointer-events: none;
}
.option-card > view,
.option-card > text { position: relative; z-index: 1; }
.option-card:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-pressed);
}

.option-icon,
.frequent-thumb {
  width: 86rpx;
  height: 86rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: var(--grad-primary);
  box-shadow:
    0 14rpx 32rpx rgba(79, 108, 255, 0.30),
    inset 0 2rpx 0 rgba(255,255,255,0.45);
  margin-bottom: 28rpx;
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(255,255,255,0.55);
}
.option-icon::before,
.frequent-thumb::before {
  content: '';
  position: absolute; top: 0; right: 0; bottom: 60%; left: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.40), transparent);
  pointer-events: none;
}
.option-icon > text {
  position: relative;
  z-index: 1;
  font-size: 38rpx;
}

.option-name {
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
  letter-spacing: 0.5rpx;
}
.option-desc {
  color: var(--text-secondary);
  font-size: 25rpx;
  line-height: 1.45;
}

/* —— Frequent section —— */
.frequent-section { margin-bottom: 32rpx; }
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 0.5rpx;
  color: var(--text-primary);
}
.section-more {
  display: flex;
  align-items: center;
  color: var(--text-secondary);
  font-size: 26rpx;
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.section-more:active { transform: scale(0.96); }
.more-arrow {
  margin-left: 6rpx;
  font-size: 32rpx;
}

.frequent-scroll { white-space: nowrap; }
.frequent-list {
  display: inline-flex;
  gap: 18rpx;
  padding-right: 32rpx;
}
.frequent-item {
  display: inline-flex;
  align-items: center;
  width: 220rpx;
  padding: 20rpx;
  border-radius: var(--radius-lg);
  background: var(--glass-fill-strong);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-glass);
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
  box-sizing: border-box;
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.frequent-item:active { transform: scale(0.96); }
.frequent-thumb {
  width: 64rpx;
  height: 64rpx;
  margin: 0 14rpx 0 0;
  background: linear-gradient(135deg, var(--accent-mint) 0%, var(--accent-blue) 100%);
  border-radius: 22rpx;
  font-size: 36rpx;
}
.thumb-icon { font-size: 36rpx; }
.frequent-name {
  max-width: 116rpx;
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.frequent-cal { display: none; }

.bottom-area { padding-bottom: 36rpx; }
.camera-btn { width: 100%; }