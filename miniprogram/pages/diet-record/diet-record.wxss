.page-title {
  margin-top: 34rpx;
  font-size: 54rpx;
  font-weight: 800;
  color: var(--text-main);
}

.page-subtitle {
  margin: 14rpx 0 34rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.meal-tabs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.tab {
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.66);
  border: 1rpx solid var(--border);
  color: var(--text-secondary);
  font-size: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(47,111,246,0.06);
}

.tab.active {
  color: #fff;
  font-weight: 800;
  background: var(--primary-gradient);
  box-shadow: var(--shadow-strong);
}

.summary-card {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 34rpx 30rpx;
  border-radius: var(--radius-xl);
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
}

.summary-item {
  flex: 1;
}

.summary-label {
  color: var(--text-secondary);
  font-size: 26rpx;
  margin-bottom: 14rpx;
}

.summary-value {
  color: var(--primary);
  font-size: 58rpx;
  font-weight: 800;
  line-height: 1;
}

.summary-unit {
  margin-left: 8rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  font-weight: 500;
}

.summary-sub {
  margin-top: 14rpx;
  color: var(--text-light);
  font-size: 24rpx;
}

.summary-divider {
  width: 1rpx;
  height: 120rpx;
  background: var(--line);
  margin: 0 26rpx;
}

.options-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
  margin-bottom: 34rpx;
}

.option-card {
  min-height: 222rpx;
  padding: 32rpx 28rpx;
  border-radius: var(--radius-xl);
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow);
  box-sizing: border-box;
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
}

.option-card:active {
  transform: scale(0.98);
}

.option-icon,
.frequent-thumb {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: radial-gradient(circle at 30% 25%, #8bd3ff, #2f6ff6 58%, #7c5cff);
  box-shadow: 0 12rpx 30rpx rgba(47,111,246,0.22);
  margin-bottom: 24rpx;
}

.option-icon text {
  font-size: 38rpx;
}

.option-name {
  color: var(--text-main);
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.option-desc {
  color: var(--text-secondary);
  font-size: 25rpx;
  line-height: 1.45;
}

.frequent-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
}

.section-more {
  display: flex;
  align-items: center;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.more-arrow {
  margin-left: 6rpx;
  font-size: 34rpx;
}

.frequent-scroll {
  white-space: nowrap;
}

.frequent-list {
  display: inline-flex;
  gap: 18rpx;
  padding-right: 32rpx;
}

.frequent-item {
  display: inline-flex;
  align-items: center;
  width: 208rpx;
  padding: 18rpx;
  border-radius: var(--radius-lg);
  background: rgba(255,255,255,0.66);
  border: 1rpx solid var(--border);
  box-shadow: 0 8rpx 24rpx rgba(47,111,246,0.06);
  box-sizing: border-box;
}

.frequent-thumb {
  width: 58rpx;
  height: 58rpx;
  margin: 0 14rpx 0 0;
  background: linear-gradient(135deg, #16c7c3, #2f6ff6);
}

.thumb-icon {
  font-size: 36rpx;
}

.frequent-name {
  max-width: 110rpx;
  color: var(--text-main);
  font-size: 26rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.frequent-cal {
  display: none;
}

.bottom-area {
  padding-bottom: 36rpx;
}

.camera-btn {
  width: 100%;
}
