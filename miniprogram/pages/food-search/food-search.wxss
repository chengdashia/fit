.page-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-main);
}

.result-card {
  margin-bottom: 24rpx;
}

.result-card:active {
  transform: scale(0.99);
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.result-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-right: 16rpx;
}

.result-tag {
  font-size: 22rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.result-tag-frequent {
  color: var(--warning);
  background: #fffbeb;
}

.result-nutri {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.result-macro {
  margin-left: 16rpx;
  color: var(--text-light);
}

.empty-state {
  text-align: center;
  color: var(--text-light);
  font-size: 28rpx;
  padding: 48rpx 0;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
}

.modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 84%;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  z-index: 101;
  padding: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 12rpx;
}

.selected-name {
  text-align: center;
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 30rpx;
  color: var(--text-main);
  margin-right: 16rpx;
}

.form-input {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  text-align: right;
}

.form-unit {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-left: 12rpx;
}

.hint {
  font-size: 24rpx;
  color: var(--text-light);
  text-align: center;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 32rpx;
}

.modal-footer .btn-secondary,
.modal-footer .btn-primary {
  flex: 1;
  margin: 0 12rpx;
}
