.home-container {
  padding-bottom: 48rpx;
}

/* Header */
.home-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.header-text {
  flex: 1;
}

.page-heading {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.greeting {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.date-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.25);
}

.avatar-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

/* Card header */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  display: flex;
  align-items: center;
}

.title-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 26rpx;
}

.icon-diet {
  background: #eff6ff;
}

.icon-training {
  background: #f0fdf4;
}

.icon-weight {
  background: #fff7ed;
}

.card-arrow {
  font-size: 40rpx;
  color: var(--text-light);
  line-height: 1;
}

/* Diet card */
.diet-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.diet-info {
  flex: 1;
}

.diet-number {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--text-main);
  line-height: 1.1;
}

.diet-unit {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.diet-remaining {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--primary-light);
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}

.diet-over {
  background: #fef2f2;
  color: var(--danger);
}

.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border);
}

.card-action-btn {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 600;
  padding: 16rpx 0;
  background: var(--primary-light);
  border-radius: 999rpx;
}

.loading-card,
.error-card {
  text-align: center;
  padding: 64rpx 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.weight-time {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.diet-ring-wrap {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.diet-ring {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.ring-center {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.ring-percent {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

/* Macros */
.macro-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.macro-item {
  width: 100%;
}

.macro-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.macro-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.macro-value {
  font-size: 26rpx;
  color: var(--text-main);
  font-weight: 600;
}

.macro-bar-bg {
  height: 12rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  overflow: hidden;
}

.macro-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.4s ease;
}

/* Training card */
.training-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.training-stat {
  display: flex;
  flex-direction: column;
}

.training-template {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.template-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.template-name {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
}

.stat-num {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text-main);
  line-height: 1.1;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.status-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.tag-not_started {
  background: #f3f4f6;
  color: var(--text-secondary);
}

.tag-in_progress,
.tag-resting {
  background: #eff6ff;
  color: var(--primary);
}

.tag-completed,
.tag-interrupted_saved {
  background: #f0fdf4;
  color: var(--success);
}

.training-cta {
  width: 100%;
  text-align: center;
  border-radius: 999rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.training-cta::after {
  border: none;
}

/* Weight card */
.weight-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.weight-stat {
  display: flex;
  flex-direction: column;
}

.weight-row {
  display: flex;
  align-items: baseline;
}

.weight-num {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text-main);
  line-height: 1.1;
}

.weight-unit {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

.weight-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.weight-target {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.target-row {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.diff-plus {
  color: var(--warning);
}

.diff-minus {
  color: var(--success);
}

.weight-chart {
  width: 100%;
  height: 240rpx;
}

/* Quick actions */
.quick-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.quick-btn {
  flex: 1;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow);
}

.quick-btn:active {
  opacity: 0.85;
}

.quick-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.quick-label {
  font-size: 26rpx;
  color: var(--text-main);
  font-weight: 500;
}

/* Empty goal state */
.empty-goal-card {
  text-align: center;
  padding: 64rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
}

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  width: 560rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  text-align: center;
  margin-bottom: 32rpx;
}

.weight-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  margin: -16rpx 0 20rpx;
}

.modal-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.modal-picker {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  background: #f9fafb;
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 28rpx;
  color: var(--text-main);
}

.modal-input {
  height: 88rpx;
  background: #f9fafb;
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-main);
  margin-bottom: 24rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-cancel {
  background: #f3f4f6;
  color: var(--text-secondary);
}

.modal-confirm {
  background: var(--primary-gradient);
  color: #fff;
}
