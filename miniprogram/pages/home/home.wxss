/* =============================================================
   Home · Liquid Glass
   ============================================================= */
.home-container { padding-bottom: 56rpx; }

/* —— 顶部 Header —— */
.home-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 0 36rpx;
}
.header-text { flex: 1; min-width: 0; }
.page-heading {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  font-weight: 600;
}
.greeting {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  line-height: 1.15;
}
.date-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* Avatar：渐变 pill + 顶部反光 */
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  background: var(--grad-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  box-shadow:
    0 12rpx 28rpx rgba(79, 108, 255, 0.32),
    inset 0 2rpx 0 rgba(255,255,255,0.45),
    inset 0 -10rpx 20rpx rgba(0,0,0,0.08);
  border: 1rpx solid rgba(255,255,255,0.55);
}
.avatar::before {
  content: '';
  position: absolute;
  inset: 0 0 50% 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.40), transparent);
  pointer-events: none;
}
.avatar-text {
  position: relative;
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
}

/* —— Card headers —— */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}
.title-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 30rpx;
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.7);
}
.title-icon::before {
  content: '';
  position: absolute; inset: 0 0 60% 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.5), transparent);
  pointer-events: none;
}
.icon-diet     { background: linear-gradient(135deg, #d8e8ff, #f1f6ff); }
.icon-training { background: linear-gradient(135deg, #d6f5ed, #f1fbf8); }
.icon-weight   { background: linear-gradient(135deg, #ffe4cf, #fff6ec); }

.card-arrow {
  font-size: 40rpx;
  color: var(--text-tertiary);
  line-height: 1;
  font-weight: 200;
}

/* —— Diet 卡片 —— */
.diet-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  gap: 24rpx;
}
.diet-info { flex: 1; min-width: 0; }
.diet-number {
  font-size: 68rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.05;
  letter-spacing: -1rpx;
  background: var(--grad-primary);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}
.diet-unit {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-left: 6rpx;
}
.diet-remaining {
  display: inline-flex;
  align-items: center;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--accent-blue);
  background: var(--primary-light);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 600;
  border: 1rpx solid rgba(79,140,255,0.18);
}
.diet-over {
  background: rgba(239, 79, 90, 0.12);
  color: var(--danger);
  border-color: rgba(239, 79, 90, 0.18);
}

/* 热量环：conic-gradient + 光晕 */
.diet-ring-wrap {
  width: 188rpx;
  height: 188rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 0 28rpx rgba(79, 140, 255, 0.18));
}
.diet-ring {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.diet-ring::after {
  content: '';
  position: absolute; inset: 18rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,255,255,0.72));
  box-shadow: inset 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.ring-center {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}
.ring-percent {
  font-size: 38rpx;
  font-weight: 800;
  background: var(--grad-primary);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* Macros */
.macro-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}
.macro-item { width: 100%; }
.macro-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.macro-name {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 600;
}
.macro-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 700;
}
.macro-bar-bg {
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(111, 136, 181, 0.10);
  overflow: hidden;
  position: relative;
}
.macro-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.45s cubic-bezier(.2,.8,.2,1);
  position: relative;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.4);
}

/* —— Card actions —— */
.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(111, 136, 181, 0.10);
}
.card-action-btn {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: var(--accent-blue);
  font-weight: 700;
  padding: 18rpx 0;
  background: var(--primary-light);
  border-radius: 999rpx;
  border: 1rpx solid rgba(79, 140, 255, 0.12);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.card-action-btn:active { transform: scale(0.96); }

/* —— 训练卡片 —— */
.training-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  gap: 24rpx;
}
.training-stat {
  display: flex;
  flex-direction: column;
}
.training-template {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  max-width: 50%;
  text-align: right;
}
.template-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}
.template-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 700;
}
.stat-num {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.05;
  background: var(--grad-primary);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}
.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.status-tag {
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}
.tag-not_started { background: rgba(111, 136, 181, 0.10); color: var(--text-secondary); }
.tag-in_progress,
.tag-resting     { background: rgba(79, 140, 255, 0.14); color: var(--accent-blue); }
.tag-completed,
.tag-interrupted_saved { background: rgba(43, 182, 115, 0.12); color: var(--success); }

/* —— CTA button（在 .training-card 中） —— */
.training-cta {
  width: 100%;
  text-align: center;
  border-radius: 999rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  font-weight: 700;
  position: relative;
  overflow: hidden;
  transition: transform .18s cubic-bezier(.2,.8,.2,1), box-shadow .18s;
}
.training-cta:active { transform: scale(0.97); }
.training-cta::after { border: none; }

/* —— Weight 卡片 —— */
.weight-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  gap: 24rpx;
}
.weight-stat {
  display: flex;
  flex-direction: column;
}
.weight-row {
  display: flex;
  align-items: baseline;
}
.weight-num {
  font-size: 60rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.05;
  background: var(--grad-primary);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}
.weight-unit {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}
.weight-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}
.weight-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}
.weight-target {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}
.target-row {
  font-size: 26rpx;
  color: var(--text-secondary);
}
.diff-plus  { color: var(--warning); }
.diff-minus { color: var(--success); }

.weight-chart {
  width: 100%;
  height: 240rpx;
  border-radius: var(--radius-md);
}

/* —— Loading / Error —— */
.loading-card,
.error-card {
  text-align: center;
  padding: 80rpx 40rpx;
}
.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}
.empty-goal-card {
  text-align: center;
  padding: 80rpx 40rpx;
}
.empty-icon {
  font-size: 88rpx;
  margin-bottom: 24rpx;
  filter: drop-shadow(0 12rpx 24rpx rgba(79, 140, 255, 0.20));
}
.empty-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
}

/* —— Quick actions —— */
.quick-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 12rpx;
}
.quick-btn {
  flex: 1;
  background: var(--glass-fill-strong);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-lg);
  padding: 32rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  backdrop-filter: var(--blur-glass);
  -webkit-backdrop-filter: var(--blur-glass);
  box-shadow: var(--shadow-glass);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.quick-btn:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-pressed);
}
.quick-icon {
  font-size: 46rpx;
  margin-bottom: 12rpx;
}
.quick-label {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 600;
}

/* —— Modal —— */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.42);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 32rpx;
  box-sizing: border-box;
}
.modal-content {
  width: 100%;
  max-width: 580rpx;
  background: var(--glass-fill-strong);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-xl);
  padding: 44rpx 40rpx 40rpx;
  box-shadow: var(--shadow-glass-hover);
  backdrop-filter: var(--blur-glass-lg);
  -webkit-backdrop-filter: var(--blur-glass-lg);
  position: relative;
  overflow: hidden;
}
.modal-content::before {
  content: '';
  position: absolute; inset: 0 0 60% 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.55), transparent);
  opacity: 0.5;
  pointer-events: none;
}
.modal-content > view,
.modal-content > text,
.modal-content > button { position: relative; z-index: 1; }

.modal-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 32rpx;
}
.weight-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  margin: -16rpx 0 20rpx;
}
.modal-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.modal-picker {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--glass-fill-soft);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 28rpx;
  color: var(--text-primary);
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
}
.modal-input {
  height: 92rpx;
  background: var(--glass-fill-soft);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
}
.modal-actions {
  display: flex;
  gap: 20rpx;
}
.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.modal-btn:active { transform: scale(0.97); }
.modal-cancel {
  background: rgba(111, 136, 181, 0.12);
  color: var(--text-secondary);
}
.modal-confirm {
  background: var(--grad-primary);
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.7);
  box-shadow: var(--shadow-glass-hover);
}