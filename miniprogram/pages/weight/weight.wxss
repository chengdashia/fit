.page-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin: 32rpx 0 32rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 800;
  color: var(--text-main);
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.hero-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 25%, #8bd3ff, #2f6ff6 48%, #7c5cff 84%);
  box-shadow: 0 16rpx 42rpx rgba(47, 111, 246, 0.22);
  border: 8rpx solid rgba(255,255,255,0.62);
}

.summary-card,
.history-card,
.modal-content {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
}

.summary-card {
  border-radius: var(--radius-xl);
  padding: 34rpx 24rpx;
  margin-bottom: 28rpx;
}

.summary-main {
  display: flex;
  align-items: center;
}

.summary-block {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.summary-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
}

.summary-value-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.summary-number {
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1;
  color: var(--primary);
}

.summary-block:nth-child(3) .summary-number {
  color: var(--text-main);
}

.summary-unit {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

.summary-divider {
  width: 1rpx;
  height: 74rpx;
  background: var(--line);
}

.trend-card {
  padding: 22rpx 22rpx 28rpx;
}

.range-tabs {
  display: flex;
  height: 72rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.54);
  border: 1rpx solid var(--border);
}

.range-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 30rpx;
  color: var(--text-secondary);
}

.range-tab.active {
  color: var(--primary);
  font-weight: 800;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 8rpx 26rpx rgba(47, 111, 246, 0.12);
}

.trend-canvas {
  width: 100%;
  height: 420rpx;
  display: block;
}

.trend-empty,
.trend-hint {
  text-align: center;
  padding: 56rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.trend-hint {
  padding-bottom: 0;
}

.trend-empty-btn {
  margin: 24rpx auto 0;
  width: 220rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: var(--primary-light);
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 700;
}

.section-header {
  margin: 40rpx 0 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 800;
}

.history-list {
  padding-bottom: 178rpx;
}

.history-card {
  border-radius: var(--radius-lg);
  padding: 26rpx 30rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-info {
  flex: 1;
  min-width: 0;
}

.history-weight {
  font-size: 42rpx;
  font-weight: 800;
  color: var(--primary);
}

.history-note,
.history-time {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.history-time {
  color: var(--text-light);
}

.history-actions {
  display: flex;
  gap: 14rpx;
}

.history-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0;
  background: rgba(255,255,255,0.72);
  color: var(--text-secondary);
  border: 1rpx solid var(--border);
}

.history-btn.edit::before {
  content: "✎";
  font-size: 32rpx;
}

.history-btn.delete::before {
  content: "⌫";
  font-size: 32rpx;
  color: var(--danger);
}

.load-more,
.no-more {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-light);
  padding: 24rpx 0;
}

.fab {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 132rpx;
  z-index: 20;
  height: 96rpx;
  border-radius: 999rpx;
  background: var(--primary-gradient);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: var(--shadow-strong);
  border: 1rpx solid rgba(255,255,255,0.72);
}

.fab-icon {
  font-size: 42rpx;
  line-height: 1;
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(17, 24, 39, 0.38);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 100;
  padding: 32rpx;
  box-sizing: border-box;
}

.modal-content {
  width: 100%;
  max-height: 82vh;
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx;
  border-bottom: 1rpx solid var(--line);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 800;
}

.modal-close {
  font-size: 44rpx;
  color: var(--text-light);
}

.modal-body {
  padding: 16rpx 34rpx;
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--line);
}

.form-row:last-child {
  border-bottom: none;
}

.form-label,
.form-input,
.form-picker {
  font-size: 30rpx;
}

.form-label {
  color: var(--text-main);
  font-weight: 600;
}

.form-input {
  flex: 1;
  margin-left: 32rpx;
  text-align: right;
  color: var(--text-main);
}

.form-picker {
  color: var(--text-main);
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 34rpx 34rpx;
}

.modal-btn {
  flex: 1;
}
