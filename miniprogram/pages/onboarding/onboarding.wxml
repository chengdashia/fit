<view class="onboarding-page">
  <scroll-view scroll-y class="scroll-body" enhanced show-scrollbar="{{false}}">
    <view class="container">
      <!-- 进度指示 -->
      <view class="step-indicator">
        <view class="step-item active">
          <view class="step-dot">1</view>
          <text class="step-label">阶段</text>
        </view>
        <view class="step-line active"></view>
        <view class="step-item active">
          <view class="step-dot">2</view>
          <text class="step-label">身体信息</text>
        </view>
        <view class="step-line active"></view>
        <view class="step-item active">
          <view class="step-dot">3</view>
          <text class="step-label">每日目标</text>
        </view>
      </view>

      <!-- ① 选择阶段目标 -->
      <view class="section">
        <view class="section-head">
          <text class="section-num">①</text>
          <view class="section-text">
            <view class="section-title">选择你的阶段目标</view>
            <view class="section-desc">不同目标将影响训练计划和营养建议</view>
          </view>
        </view>
        <view class="goal-row">
          <view
            class="goal-card {{form.goal_stage === item.value ? 'selected' : ''}}"
            wx:for="{{goalOptions}}"
            wx:key="value"
            data-value="{{item.value}}"
            bindtap="selectGoal"
          >
            <view class="goal-icon-wrap {{item.value}}">
              <text class="goal-emoji">{{item.emoji}}</text>
            </view>
            <view class="goal-label">{{item.label}}</view>
            <view class="goal-desc">{{item.desc}}</view>
            <view class="goal-check">
              <text wx:if="{{form.goal_stage === item.value}}" class="check-mark">✓</text>
            </view>
          </view>
        </view>
      </view>

      <!-- ② 身体信息 -->
      <view class="section">
        <view class="section-head">
          <text class="section-num">②</text>
          <view class="section-text">
            <view class="section-title">填写你的身体信息</view>
            <view class="section-desc">准确的信息有助于计算更精准的目标</view>
          </view>
        </view>
        <view class="list-card">
          <view class="list-row" data-field="current_weight_kg" bindtap="openFieldEditor">
            <text class="row-icon">⚖</text>
            <text class="row-label">当前体重</text>
            <text class="row-value">{{form.current_weight_kg || '请填写'}}<text class="row-unit" wx:if="{{form.current_weight_kg}}"> kg</text></text>
            <text class="row-arrow">›</text>
          </view>
          <view class="list-row" data-field="target_weight_kg" bindtap="openFieldEditor">
            <text class="row-icon">🎯</text>
            <text class="row-label">目标体重</text>
            <text class="row-value">{{form.target_weight_kg || '请填写'}}<text class="row-unit" wx:if="{{form.target_weight_kg}}"> kg</text></text>
            <text class="row-arrow">›</text>
          </view>
          <view class="list-row" data-field="height_cm" bindtap="openFieldEditor">
            <text class="row-icon">📏</text>
            <text class="row-label">身高</text>
            <text class="row-value">{{form.height_cm || '选填'}}<text class="row-unit" wx:if="{{form.height_cm}}"> cm</text></text>
            <text class="row-arrow">›</text>
          </view>
          <view class="list-row" data-field="gender" bindtap="openGenderPicker">
            <text class="row-icon">👤</text>
            <text class="row-label">性别</text>
            <text class="row-value">{{genderLabel}}</text>
            <text class="row-arrow">›</text>
          </view>
          <view class="list-row last">
            <text class="row-icon">📅</text>
            <text class="row-label">出生年份</text>
            <picker mode="selector" range="{{birthYears}}" value="{{birthYearIndex}}" bindchange="onBirthYearChange">
              <view class="row-value picker-val">{{form.birth_year}} 年 ›</view>
            </picker>
          </view>
        </view>
      </view>

      <!-- ③ 每日目标 -->
      <view class="section">
        <view class="section-head">
          <text class="section-num">③</text>
          <view class="section-text">
            <view class="section-title">设定每日目标</view>
            <view class="section-desc">我们将根据你的目标为你推荐每日摄入</view>
          </view>
        </view>
        <view class="list-card">
          <view class="list-row" data-field="calorie_target" bindtap="openFieldEditor">
            <text class="row-icon">🔥</text>
            <text class="row-label">每日热量目标</text>
            <text class="row-value">{{form.calorie_target || '请填写'}}<text class="row-unit" wx:if="{{form.calorie_target}}"> kcal</text></text>
            <text class="row-arrow">›</text>
          </view>
          <view class="list-row last" data-field="protein_target" bindtap="openFieldEditor">
            <text class="row-icon">🥩</text>
            <text class="row-label">每日蛋白质目标</text>
            <text class="row-value">{{form.protein_target || '请填写'}}<text class="row-unit" wx:if="{{form.protein_target}}"> g</text></text>
            <text class="row-arrow">›</text>
          </view>
        </view>
      </view>

      <view class="disclaimer">
        <text class="disclaimer-icon">✓</text>
        <text class="disclaimer-text">设置信息将用于驱动「首页·饮食·体重」的数据展示，你可以随时在「我的」页面编辑修改</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="footer safe-bottom">
    <view class="btn-submit" bindtap="submit">完成设置</view>
  </view>

  <!-- 字段编辑弹窗 -->
  <view class="modal-overlay" wx:if="{{showFieldModal}}" bindtap="closeFieldModal">
    <view class="modal-box" catchtap="noop">
      <view class="modal-title">{{fieldModalTitle}}</view>
      <input
        class="modal-input"
        type="{{fieldModalType}}"
        placeholder="{{fieldModalPlaceholder}}"
        value="{{fieldModalValue}}"
        focus="{{showFieldModal}}"
        bindinput="onFieldModalInput"
      />
      <view class="modal-actions">
        <view class="modal-btn cancel" bindtap="closeFieldModal">取消</view>
        <view class="modal-btn confirm" bindtap="saveFieldModal">确定</view>
      </view>
    </view>
  </view>
</view>
