.onboarding-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-page);
}

.scroll-body {
  flex: 1;
  height: calc(100vh - 160rpx);
}

.onboarding-page .container {
  padding: 24rpx 32rpx 48rpx;
}

/* 进度指示 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  padding: 0 8rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e5e7eb;
  color: #9ca3af;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.step-item.active .step-dot {
  background: var(--primary-gradient);
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(59, 130, 246, 0.35);
}

.step-label {
  font-size: 22rpx;
  color: #9ca3af;
}

.step-item.active .step-label {
  color: var(--primary);
  font-weight: 600;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: #e5e7eb;
  margin: 0 12rpx 28rpx;
  border-radius: 2rpx;
}

.step-line.active {
  background: var(--primary);
}

/* 区块 */
.section {
  margin-bottom: 40rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.section-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  margin-right: 12rpx;
  line-height: 1.2;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 6rpx;
}

.section-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

/* 目标卡片 - 并排 */
.goal-row {
  display: flex;
  gap: 20rpx;
}

.goal-card {
  flex: 1;
  position: relative;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx 24rpx;
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow);
  text-align: center;
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
}

.goal-card.selected {
  border-color: var(--primary);
  background: rgba(239, 246, 255, 0.72);
}

.goal-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin: 0 auto 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.goal-icon-wrap.fat_loss {
  background: #eff6ff;
}

.goal-icon-wrap.muscle_gain {
  background: #f5f3ff;
}

.goal-emoji {
  font-size: 44rpx;
}

.goal-label {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.goal-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

.goal-check {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
}

.goal-card.selected .goal-check {
  background: var(--primary);
  border-color: var(--primary);
}

.check-mark {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

/* 列表卡片 */
.list-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  overflow: hidden;
  border: 1rpx solid var(--border);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
}

.list-row {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--line);
}

.list-row.last {
  border-bottom: none;
}

.row-icon {
  font-size: 32rpx;
  width: 48rpx;
  text-align: center;
  margin-right: 16rpx;
}

.row-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-main);
}

.row-value {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-right: 8rpx;
}

.row-value.picker-val {
  color: var(--text-main);
  font-weight: 500;
}

.row-unit {
  font-size: 24rpx;
}

.row-arrow {
  font-size: 32rpx;
  color: var(--text-light);
}

/* 免责声明 */
.disclaimer {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  margin-top: 8rpx;
}

.disclaimer-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #dcfce7;
  color: var(--success);
  font-size: 20rpx;
  text-align: center;
  line-height: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.disclaimer-text {
  font-size: 22rpx;
  color: var(--text-light);
  line-height: 1.5;
}

/* 底部 */
.footer {
  padding: 20rpx 32rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 -8rpx 28rpx rgba(47, 111, 246, 0.08);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
}

.btn-submit {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.35);
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.modal-box {
  width: 580rpx;
  background: var(--bg-card-strong);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow-strong);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-input {
  height: 88rpx;
  background: #f9fafb;
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 32rpx;
  margin-bottom: 32rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  background: #f3f4f6;
  color: var(--text-secondary);
}

.modal-btn.confirm {
  background: var(--primary-gradient);
  color: #fff;
}
