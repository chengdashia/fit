/* =============================================================
   Training · Liquid Glass
   ============================================================= */
.page-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin: 28rpx 0 36rpx;
}
.hero-title {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.1;
  letter-spacing: -0.5rpx;
}
.hero-subtitle {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.history-dot {
  min-width: 96rpx;
  height: 76rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: var(--glass-fill-strong);
  color: var(--text-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-glass);
  border: 1rpx solid var(--glass-border);
  font-size: 26rpx;
  font-weight: 700;
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.history-dot:active { transform: scale(0.95); }

/* —— Split plan card —— */
.split-card,
.split-setup {
  position: relative;
  overflow: hidden;
  margin-bottom: 28rpx;
}
.split-card::after,
.split-setup::after {
  content: '';
  position: absolute;
  right: -100rpx; top: -100rpx;
  width: 260rpx; height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139, 109, 255, 0.18) 0%, transparent 70%);
  pointer-events: none;
}
.split-card > view,
.split-card > text,
.split-setup > view,
.split-setup > text { position: relative; z-index: 1; }

.split-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}
.split-kicker {
  font-size: 22rpx;
  color: var(--accent-blue);
  font-weight: 800;
  letter-spacing: 1.5rpx;
  text-transform: uppercase;
  background: var(--primary-light);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(79, 140, 255, 0.14);
  align-self: flex-start;
}
.split-title {
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
}
.split-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}
.split-start {
  flex-shrink: 0;
  padding: 0 32rpx;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 28rpx;
}
.split-days {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}
.split-day {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: var(--radius-md);
  background: rgba(111, 136, 181, 0.08);
  color: var(--text-secondary);
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid rgba(111, 136, 181, 0.06);
}
.split-day.today {
  background: var(--grad-primary);
  color: #fff;
  font-weight: 800;
  border-color: rgba(255,255,255,0.5);
  box-shadow: 0 12rpx 28rpx rgba(79, 108, 255, 0.28);
}

.split-setup-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}
.split-setup-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 28rpx;
}
.split-setup-btn {
  height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
}

/* —— Filter chips —— */
.section-label {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 22rpx;
  letter-spacing: 0.5rpx;
}
.filter-scroll {
  white-space: nowrap;
  margin-bottom: 28rpx;
}
.filter-list {
  display: inline-flex;
  gap: 20rpx;
  padding-right: 32rpx;
}
.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  height: 68rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  background: var(--glass-fill-soft);
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 700;
  border: 1rpx solid var(--glass-border);
  box-shadow: 0 6rpx 20rpx rgba(47, 80, 160, 0.06);
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.filter-chip:active { transform: scale(0.95); }
.filter-chip.active {
  color: #fff;
  font-weight: 800;
  background: var(--grad-primary);
  border-color: rgba(255,255,255,0.55);
  box-shadow: 0 12rpx 28rpx rgba(79, 108, 255, 0.28);
}

/* —— Template card —— */
.template-list { padding-bottom: 180rpx; }
.template-card {
  position: relative;
  overflow: hidden;
  background: var(--glass-fill-strong);
  border-radius: var(--radius-xl);
  padding: 36rpx 32rpx;
  margin-bottom: 26rpx;
  box-shadow: var(--shadow-glass);
  border: 1rpx solid var(--glass-border);
  backdrop-filter: var(--blur-glass);
  -webkit-backdrop-filter: var(--blur-glass);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.template-card::before {
  content: '';
  position: absolute; inset: 0 0 60% 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.45), transparent);
  pointer-events: none;
}
.template-card::after {
  content: '';
  position: absolute;
  right: -70rpx; top: -70rpx;
  width: 200rpx; height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139, 109, 255, 0.14) 0%, transparent 70%);
  pointer-events: none;
}
.template-card > view,
.template-card > text { position: relative; z-index: 1; }
.template-card:active { transform: scale(0.99); }

.template-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}
.template-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 30rpx;
  background: var(--grad-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 800;
  margin-right: 26rpx;
  box-shadow:
    0 14rpx 30rpx rgba(79, 108, 255, 0.30),
    inset 0 2rpx 0 rgba(255,255,255,0.45);
  border: 1rpx solid rgba(255,255,255,0.55);
  position: relative;
  overflow: hidden;
}
.template-icon::before {
  content: '';
  position: absolute; inset: 0 0 60% 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.45), transparent);
  pointer-events: none;
}
.template-icon.muscle_gain { background: linear-gradient(135deg, var(--accent-violet) 0%, #5d3eff 100%); }
.template-icon.fat_loss    { background: linear-gradient(135deg, var(--accent-amber) 0%, #ff7a3d 100%); }

.template-main {
  flex: 1;
  min-width: 0;
}
.template-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
}
.template-name {
  max-width: 360rpx;
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: -0.5rpx;
}
.template-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--accent-blue);
  background: var(--primary-light);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 800;
  border: 1rpx solid rgba(79, 140, 255, 0.14);
}
.template-last {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.more-btn {
  color: var(--text-tertiary);
  font-size: 36rpx;
  padding-left: 14rpx;
  font-weight: 200;
}

.template-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.template-count {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.count-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.count-value {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary);
}
.start-btn {
  width: 220rpx;
  min-height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
  position: relative;
  z-index: 1;
}

.template-actions {
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(111, 136, 181, 0.10);
}
.action-icon,
.utility-btn {
  font-size: 24rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: var(--glass-fill-soft);
  color: var(--text-secondary);
  border: 1rpx solid var(--glass-border);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.action-icon:active,
.utility-btn:active { transform: scale(0.94); }
.action-icon.danger {
  color: var(--danger);
  background: rgba(239, 79, 90, 0.10);
  border-color: rgba(239, 79, 90, 0.14);
}

.utility-row {
  display: flex;
  gap: 18rpx;
  margin: -140rpx 0 170rpx;
}
.utility-btn {
  flex: 1;
  text-align: center;
  color: var(--accent-blue);
  font-weight: 800;
  background: var(--glass-fill-strong);
}

/* —— Empty state —— */
.empty-state {
  text-align: center;
  padding: 80rpx 44rpx;
}
.empty-icon {
  font-size: 88rpx;
  color: var(--accent-blue);
  margin-bottom: 26rpx;
  filter: drop-shadow(0 12rpx 24rpx rgba(79, 140, 255, 0.20));
}
.empty-title,
.empty-desc { display: block; }
.empty-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 36rpx;
}
.empty-create { width: 100%; }

/* —— Create FAB —— */
.create-fab {
  position: fixed;
  right: 32rpx;
  bottom: 132rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 240rpx;
  height: 96rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  background: var(--grad-primary);
  box-shadow: 0 18rpx 50rpx rgba(79, 108, 255, 0.36);
  border: 1rpx solid rgba(255, 255, 255, 0.55);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
  position: fixed;
}
.create-fab:active { transform: scale(0.97); }
.create-plus {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #fff;
  color: var(--accent-blue);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  line-height: 46rpx;
  font-weight: 600;
}