.page-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.form-card {
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 26rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  width: 130rpx;
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-main);
  text-align: right;
}

.form-unit {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-left: 12rpx;
  width: 70rpx;
  text-align: right;
}

.meal-selector {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.meal-pill {
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg-page);
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  margin-left: 12rpx;
}

.meal-pill.active {
  background: var(--primary-gradient);
  color: #fff;
  font-weight: 600;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  color: var(--text-main);
  margin-bottom: 32rpx;
}

.bottom-area {
  margin-bottom: 32rpx;
}

.submit-btn {
  width: 100%;
}
