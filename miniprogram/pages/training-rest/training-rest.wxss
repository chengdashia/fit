.timer-card {
  margin: 46rpx 0 28rpx;
  padding: 54rpx 32rpx 42rpx;
  border-radius: var(--radius-xl);
  text-align: center;
  background: linear-gradient(145deg, rgba(255,255,255,0.72), rgba(235,244,255,0.62));
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
}

.timer-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 50rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: var(--text-main);
  background: rgba(255,255,255,0.72);
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.timer-number {
  display: block;
  color: var(--text-main);
  font-size: 110rpx;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 36rpx;
}

.timer-ring {
  width: 310rpx;
  height: 310rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: conic-gradient(#2f6ff6 var(--progress), rgba(47,111,246,0.12) var(--progress));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 0 2rpx rgba(255,255,255,0.7);
}

.ring-bg {
  width: 250rpx;
  height: 250rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.82);
}

.info-card {
  display: flex;
  flex-direction: column;
  margin-bottom: 18rpx;
}

.info-card.next {
  border-left: 8rpx solid var(--primary);
}

.info-label {
  color: var(--text-light);
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.info-name {
  color: var(--text-main);
  font-size: 36rpx;
  font-weight: 800;
  margin-bottom: 14rpx;
}

.info-tag {
  display: inline-flex;
  min-height: 52rpx;
  align-items: center;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: var(--text-secondary);
  background: rgba(255,255,255,0.64);
  border: 1rpx solid var(--border);
  font-size: 26rpx;
}

.extend-bar {
  display: flex;
  gap: 18rpx;
  margin: 30rpx 0;
}

.extend-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.66);
  color: var(--text-main);
  border: 1rpx solid var(--border);
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(47,111,246,0.08);
}

.bottom-actions {
  padding: 16rpx 0 48rpx;
}

.action-main {
  width: 100%;
}

.action-secondary {
  margin-top: 18rpx;
  text-align: center;
  color: var(--danger);
  font-size: 28rpx;
  padding: 20rpx 0;
}
