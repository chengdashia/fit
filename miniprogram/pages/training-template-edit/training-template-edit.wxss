.base-form {
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: var(--text-main);
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  margin-left: 32rpx;
  text-align: right;
  font-size: 30rpx;
  color: var(--text-main);
}

.form-picker {
  font-size: 30rpx;
  color: var(--text-main);
  text-align: right;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  margin: 32rpx 0 24rpx;
}

.unit-list {
  margin-bottom: 24rpx;
}

.unit-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow);
}

.unit-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.unit-type-tag {
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  color: #fff;
}

.unit-type-tag.normal {
  background: linear-gradient(135deg, #3b82f6, #60a5fa);
}

.unit-type-tag.superset {
  background: linear-gradient(135deg, #8b5cf6, #a78bfa);
}

.unit-type-tag.dropset {
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
}

.unit-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.unit-move {
  font-size: 28rpx;
  color: var(--primary);
  padding: 8rpx 16rpx;
  background: var(--primary-light);
  border-radius: 999rpx;
}

.unit-remove {
  font-size: 32rpx;
  color: var(--danger);
  padding: 4rpx 16rpx;
  background: #fee2e2;
  border-radius: 999rpx;
}

.unit-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.unit-name-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  width: 140rpx;
}

.unit-name-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-main);
  text-align: right;
}

.sub-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.sub-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  width: 140rpx;
}

.sub-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-main);
  text-align: right;
}

.sets-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 0 16rpx;
}

.sets-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.add-sub {
  font-size: 24rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}

.set-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.set-row:last-child {
  border-bottom: none;
}

.set-index {
  font-size: 24rpx;
  color: var(--text-secondary);
  width: 100rpx;
  flex-shrink: 0;
}

.set-input {
  flex: 1;
  min-width: 80rpx;
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  padding: 14rpx 16rpx;
  font-size: 28rpx;
  text-align: center;
}

.ex-name {
  flex: 2;
  min-width: 120rpx;
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  padding: 14rpx 16rpx;
  font-size: 28rpx;
}

.set-remove {
  font-size: 28rpx;
  color: var(--danger);
  padding: 8rpx 14rpx;
}

.add-unit-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.add-unit-btn {
  flex: 1;
  text-align: center;
  background: #fff;
  color: var(--primary);
  border: 2rpx solid #bfdbfe;
  border-radius: var(--radius-md);
  padding: 24rpx 0;
  font-size: 26rpx;
  font-weight: 600;
}

.save-btn {
  margin-bottom: 60rpx;
}
