/* =============================================================
   Diet · Liquid Glass
   ============================================================= */

/* —— 日期 Bar —— */
.date-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  gap: 14rpx;
}
.arrow {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: var(--accent-blue);
  background: var(--glass-fill-strong);
  border: 1rpx solid var(--glass-border);
  border-radius: 28rpx;
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
  box-shadow: 0 6rpx 18rpx rgba(47, 80, 160, 0.06);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.arrow:active { transform: scale(0.94); }
.date-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 14rpx 36rpx;
  background: var(--glass-fill-strong);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-glass);
  backdrop-filter: var(--blur-glass);
  -webkit-backdrop-filter: var(--blur-glass);
  letter-spacing: 0.5rpx;
}

/* —— Meal section sticky header —— */
.meal-section {
  margin-bottom: 32rpx;
  position: relative;
}
.meal-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 0 18rpx;
  padding: 18rpx 24rpx;
  background: var(--glass-fill-soft);
  border: 1rpx solid rgba(255,255,255,0.55);
  border-radius: var(--radius-md);
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
  position: sticky;
  top: 0;
  z-index: 5;
}
.meal-section-title {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
}
.meal-name {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: 0.5rpx;
}
.meal-subtotal {
  font-size: 24rpx;
  color: var(--accent-blue);
  font-weight: 700;
}
.meal-add-btn {
  font-size: 24rpx;
  color: var(--accent-blue);
  font-weight: 700;
  padding: 8rpx 22rpx;
  background: var(--primary-light);
  border-radius: 999rpx;
  border: 1rpx solid rgba(79, 140, 255, 0.14);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.meal-add-btn:active { transform: scale(0.95); }

/* —— Summary 卡：渐变 + 玻璃 + 光晕 —— */
.summary-card {
  position: relative;
  overflow: hidden;
  color: #fff;
  border-radius: var(--radius-xl);
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  background: var(--grad-primary);
  box-shadow: 0 22rpx 60rpx rgba(79, 108, 255, 0.32);
  border: 1rpx solid rgba(255,255,255,0.4);
}
.summary-card::before {
  content: '';
  position: absolute; inset: 0 0 50% 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.32), transparent);
  pointer-events: none;
}
.summary-card::after {
  content: '';
  position: absolute;
  right: -120rpx; top: -120rpx;
  width: 280rpx; height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.32) 0%, transparent 70%);
  pointer-events: none;
}
.summary-card > view,
.summary-card > text { position: relative; z-index: 1; }
.summary-title {
  font-size: 26rpx;
  opacity: 0.88;
  margin-bottom: 18rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}
.summary-main {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 24rpx;
}
.summary-block { text-align: center; }
.summary-num {
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1;
  color: #fff;
}
.summary-unit {
  font-size: 24rpx;
  opacity: 0.86;
  margin-left: 8rpx;
}
.summary-divider {
  width: 2rpx;
  height: 70rpx;
  background: rgba(255, 255, 255, 0.32);
}
.target-row {
  font-size: 24rpx;
  opacity: 0.92;
  margin-bottom: 14rpx;
}
.progress-bg {
  height: 14rpx;
  background: rgba(255, 255, 255, 0.28);
  border-radius: 999rpx;
  overflow: hidden;
  position: relative;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #fff 0%, #f5f8ff 100%);
  border-radius: 999rpx;
  max-width: 100%;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.6);
  transition: width .45s cubic-bezier(.2,.8,.2,1);
}

/* —— Section header —— */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: 0.5rpx;
}
.revoke-btn {
  font-size: 26rpx;
  color: var(--accent-blue);
  font-weight: 700;
  padding: 6rpx 18rpx;
  background: var(--primary-light);
  border-radius: 999rpx;
  border: 1rpx solid rgba(79, 140, 255, 0.14);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.revoke-btn:active { transform: scale(0.95); }

/* —— Record card —— */
.record-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 22rpx;
}
.record-card::after {
  content: '';
  position: absolute;
  right: -80rpx; top: -80rpx;
  width: 200rpx; height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139, 109, 255, 0.12) 0%, transparent 70%);
  pointer-events: none;
}
.record-card > view,
.record-card > text { position: relative; z-index: 1; }
.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid rgba(111, 136, 181, 0.12);
}
.record-time {
  font-size: 26rpx;
  color: var(--text-secondary);
}
.record-source {
  font-size: 22rpx;
  color: var(--accent-blue);
  background: var(--primary-light);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(79, 140, 255, 0.12);
  font-weight: 700;
}

.food-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(111, 136, 181, 0.08);
}
.food-row:last-child { border-bottom: none; }
.food-main {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}
.food-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.food-weight {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}
.food-nutri { text-align: right; }
.food-cal {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--accent-blue);
}
.food-macro {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.record-total {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: right;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(111, 136, 181, 0.10);
}

.record-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 18rpx;
}
.record-action {
  font-size: 26rpx;
  color: var(--accent-blue);
  font-weight: 700;
  padding: 10rpx 22rpx;
  background: var(--primary-light);
  border-radius: 999rpx;
  border: 1rpx solid rgba(79, 140, 255, 0.12);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.record-action:active { transform: scale(0.95); }
.record-action.danger {
  color: var(--danger);
  background: rgba(239, 79, 90, 0.10);
  border-color: rgba(239, 79, 90, 0.14);
}

/* —— Empty states —— */
.empty-state {
  text-align: center;
  color: var(--text-tertiary);
  font-size: 28rpx;
  padding: 56rpx 0;
}
.meal-empty {
  text-align: center;
  padding: 36rpx 24rpx;
  margin-bottom: 8rpx;
}
.meal-empty-text {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-bottom: 16rpx;
}
.meal-empty-btn {
  display: inline-block;
  font-size: 26rpx;
  color: var(--accent-blue);
  font-weight: 700;
  padding: 8rpx 22rpx;
  background: var(--primary-light);
  border-radius: 999rpx;
  border: 1rpx solid rgba(79, 140, 255, 0.14);
}
.empty-btn {
  display: inline-block;
  margin-top: 24rpx;
  color: var(--accent-blue);
  font-weight: 700;
  padding: 10rpx 28rpx;
  background: var(--primary-light);
  border-radius: 999rpx;
}

/* —— FAB —— */
.fab {
  position: fixed;
  left: 64rpx;
  right: 64rpx;
  bottom: 48rpx;
  background: var(--grad-primary);
  color: #fff;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 50rpx rgba(79, 108, 255, 0.36);
  border: 1rpx solid rgba(255, 255, 255, 0.55);
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.fab:active { transform: scale(0.97); }
.fab-text { color: #fff; }

/* —— Edit modal —— */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.42);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 32rpx;
  box-sizing: border-box;
}
.modal-content {
  width: 100%;
  max-width: 660rpx;
  max-height: 84vh;
  background: var(--glass-fill-strong);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-xl);
  padding: 40rpx 36rpx;
  box-shadow: var(--shadow-glass-hover);
  backdrop-filter: var(--blur-glass-lg);
  -webkit-backdrop-filter: var(--blur-glass-lg);
  overflow: hidden;
  position: relative;
}
.modal-content::before {
  content: '';
  position: absolute; inset: 0 0 60% 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.50), transparent);
  pointer-events: none;
}
.modal-content > view,
.modal-content > text,
.modal-content > button { position: relative; z-index: 1; }

.edit-modal {
  display: flex;
  flex-direction: column;
}
.edit-scroll {
  max-height: 56vh;
  margin-bottom: 24rpx;
}
.edit-food-item {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(111, 136, 181, 0.10);
}
.edit-food-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
}
.edit-input {
  height: 76rpx;
  background: var(--glass-fill-soft);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 12rpx;
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
}
.edit-row {
  display: flex;
  gap: 14rpx;
}
.edit-input.half { flex: 1; }
.edit-input.third { flex: 1; }
.edit-meta {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
}
.edit-meta-item {
  flex: 1;
  text-align: center;
  background: var(--glass-fill-soft);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-md);
  padding: 18rpx 8rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
}
.modal-title {
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
  margin-bottom: 28rpx;
  color: var(--text-primary);
}
.modal-actions {
  display: flex;
  gap: 20rpx;
}
.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  transition: transform .18s cubic-bezier(.2,.8,.2,1);
}
.modal-btn:active { transform: scale(0.97); }
.modal-cancel {
  background: rgba(111, 136, 181, 0.12);
  color: var(--text-secondary);
}
.modal-confirm {
  background: var(--grad-primary);
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.7);
  box-shadow: var(--shadow-glass-hover);
}