/* =============================================================
   Fit App · Liquid Glass Design Tokens
   - Apple-style frosted glass, soft aurora gradients
   - 三档玻璃：.glass / .glass-strong / .glass-frost
   - 微动效：.tap-scale 全局按下反馈
   ============================================================= */

page {
  /* —— 主色调：低饱和·高明度柔和蓝紫渐变 —— */
  --accent-blue:    #4f8cff;
  --accent-blue-2:  #4f6cff;
  --accent-violet:  #8b6dff;
  --accent-mint:    #5ac8c0;
  --accent-amber:   #ffb15c;
  --accent-rose:    #ff7a8a;

  /* —— 文字层级 —— */
  --text-primary:   #0c1424;
  --text-secondary: #5a6377;
  --text-tertiary:  #98a1b4;

  /* —— 玻璃三档 —— */
  --glass-fill:        rgba(255, 255, 255, 0.55);
  --glass-fill-strong: rgba(255, 255, 255, 0.78);
  --glass-fill-soft:   rgba(255, 255, 255, 0.38);
  --glass-border:      rgba(255, 255, 255, 0.85);
  --glass-inner-hi:    rgba(255, 255, 255, 0.92);
  --glass-inner-lo:    rgba(175, 195, 230, 0.10);

  /* —— 圆角体系 —— */
  --radius-xs: 14rpx;
  --radius-sm: 22rpx;
  --radius-md: 32rpx;
  --radius-lg: 44rpx;
  --radius-xl: 56rpx;

  /* —— 阴影体系 —— */
  --shadow-glass:
    0 24rpx 60rpx rgba(47, 80, 160, 0.10),
    inset 0 1rpx 0 var(--glass-inner-hi),
    inset 0 -1rpx 0 var(--glass-inner-lo);
  --shadow-glass-hover:
    0 32rpx 80rpx rgba(47, 80, 160, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 1);
  --shadow-lift:    0 18rpx 40rpx rgba(78, 100, 170, 0.14);
  --shadow-pressed: 0 6rpx 14rpx rgba(78, 100, 170, 0.18);

  /* —— 模糊体系：saturate+blur 提升光感 —— */
  --blur-glass:    saturate(180%) blur(40rpx);
  --blur-glass-md: saturate(160%) blur(28rpx);
  --blur-glass-lg: saturate(200%) blur(60rpx);

  /* —— 渐变体系 —— */
  --grad-primary: linear-gradient(135deg, #6aa1ff 0%, #4f6cff 50%, #8b6dff 100%);
  --grad-success: linear-gradient(135deg, #5fe0a7 0%, #2bb673 100%);
  --grad-danger:  linear-gradient(135deg, #ff8a8a 0%, #ef4f5a 100%);
  --grad-amber:   linear-gradient(135deg, #ffd591 0%, #ff9f43 100%);
  --grad-glass:   linear-gradient(135deg,
                   rgba(255,255,255,0.70) 0%,
                   rgba(255,255,255,0.32) 100%);

  /* —— 极光背景：aurora —— */
  --bg-aurora:
    radial-gradient(circle at 12% 8%,  rgba(168, 192, 255, 0.55) 0%, transparent 38%),
    radial-gradient(circle at 92% 14%, rgba(193, 168, 255, 0.45) 0%, transparent 42%),
    radial-gradient(circle at 50% 100%, rgba(180, 232, 255, 0.40) 0%, transparent 48%),
    linear-gradient(165deg, #fafcff 0%, #eef3ff 50%, #f7f4ff 100%);

  /* —— 兼容旧 token（保证已有页面不报错） —— */
  --primary:        var(--accent-blue);
  --primary-deep:   #2457e6;
  --primary-light:  rgba(79, 140, 255, 0.12);
  --primary-gradient: var(--grad-primary);
  --aqua:           var(--accent-mint);
  --violet:         var(--accent-violet);
  --success:        #2bb673;
  --warning:        var(--accent-amber);
  --danger:         #ef4f5a;
  --text-main:      var(--text-primary);
  --text-light:     var(--text-tertiary);
  --bg-page:        var(--bg-aurora);
  --bg-card:        var(--glass-fill);
  --bg-card-strong: var(--glass-fill-strong);
  --border:         var(--glass-border);
  --line:           rgba(111, 136, 181, 0.16);
  --radius-sm-old:  var(--radius-xs);
  --shadow:         var(--shadow-glass);
  --shadow-strong:  var(--shadow-glass-hover);

  background: var(--bg-aurora);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
               'Helvetica Neue', Arial, sans-serif;
  font-variant-numeric: tabular-nums;
}

/* =============================================================
   基础容器
   ============================================================= */
.container {
  min-height: 100vh;
  padding: 32rpx 32rpx 40rpx;
  box-sizing: border-box;
}

.safe-bottom {
  padding-bottom: 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* =============================================================
   Liquid Glass mixin
   ============================================================= */
.glass {
  position: relative;
  overflow: hidden;
  background: var(--glass-fill);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-lg);
  backdrop-filter: var(--blur-glass);
  -webkit-backdrop-filter: var(--blur-glass);
  box-shadow: var(--shadow-glass);
}
.glass::before {
  content: '';
  position: absolute; left: 0; right: 0; top: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.55), transparent);
  opacity: 0.55;
  pointer-events: none;
  border-radius: inherit;
}
.glass > view,
.glass > text,
.glass > image,
.glass > button,
.glass > input,
.glass > navigator { position: relative; z-index: 1; }

.glass-strong {
  background: var(--glass-fill-strong);
  backdrop-filter: var(--blur-glass-lg);
  -webkit-backdrop-filter: var(--blur-glass-lg);
  box-shadow: var(--shadow-glass-hover);
}
.glass-frost {
  background: var(--glass-fill-soft);
  border: 1rpx solid rgba(255,255,255,0.55);
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
  box-shadow: 0 8rpx 26rpx rgba(47, 80, 160, 0.06);
}

/* =============================================================
   卡片（兼容旧 .card 命名）
   ============================================================= */
.card {
  position: relative;
  overflow: hidden;
  background: var(--glass-fill);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-glass);
  border: 1rpx solid var(--glass-border);
  backdrop-filter: var(--blur-glass);
  -webkit-backdrop-filter: var(--blur-glass);
}
.card::before {
  content: '';
  position: absolute; left: 0; right: 0; top: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.45), transparent);
  opacity: 0.5;
  pointer-events: none;
  border-radius: inherit;
}
.card > view,
.card > text,
.card > image,
.card > button,
.card > input,
.card > navigator { position: relative; z-index: 1; }

.glass-panel {
  position: relative;
  overflow: hidden;
  background: var(--glass-fill);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-glass);
  backdrop-filter: var(--blur-glass);
  -webkit-backdrop-filter: var(--blur-glass);
}
.glass-panel::before {
  content: '';
  position: absolute; left: 0; right: 0; top: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.45), transparent);
  opacity: 0.5;
  pointer-events: none;
  border-radius: inherit;
}
.glass-panel > view,
.glass-panel > text,
.glass-panel > image,
.glass-panel > button,
.glass-panel > input,
.glass-panel > navigator { position: relative; z-index: 1; }

/* =============================================================
   按钮
   ============================================================= */
.btn-primary {
  background: var(--grad-primary);
  color: #fff;
  border-radius: 999rpx;
  min-height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: var(--shadow-glass-hover);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}
.btn-primary::after { border: none; }

.btn-secondary {
  background: var(--glass-fill-strong);
  color: var(--accent-blue);
  border-radius: 999rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  border: 1rpx solid var(--glass-border);
  box-shadow: 0 8rpx 28rpx rgba(47, 80, 160, 0.08);
  backdrop-filter: var(--blur-glass-md);
  -webkit-backdrop-filter: var(--blur-glass-md);
  box-sizing: border-box;
}
.btn-secondary::after { border: none; }

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
  min-height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  text-align: center;
  box-sizing: border-box;
}

/* =============================================================
   微动效：全局点击反馈
   ============================================================= */
.tap-scale {
  transition: transform .18s cubic-bezier(.2,.8,.2,1),
              box-shadow .18s ease;
}
.tap-scale:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-pressed);
}

/* =============================================================
   通用工具类
   ============================================================= */
.section-title {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
  letter-spacing: 0;
}
.section-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}

.badge-pill {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  background: var(--primary-light);
  color: var(--accent-blue);
}

.input-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.input-row:last-child { border-bottom: none; }
.input-label {
  font-size: 30rpx;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}
.input-value {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
}
.input-placeholder { color: var(--text-tertiary); }

/* —— 字体层级 —— */
.page-heading,
.page-title {
  letter-spacing: 0;
}

button {
  margin: 0;
  padding: 0;
}
button::after { border: none; }

input {
  min-height: 44rpx;
}

/* —— 模态遮罩（统一） —— */
.liquid-mask {
  position: fixed;
  top: 0; right: 0; bottom: 0; left: 0;
  background: rgba(17, 24, 39, 0.38);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 32rpx;
  box-sizing: border-box;
}
.liquid-modal {
  width: 100%;
  max-width: 620rpx;
  max-height: 82vh;
  background: var(--glass-fill-strong);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-glass-hover);
  backdrop-filter: var(--blur-glass-lg);
  -webkit-backdrop-filter: var(--blur-glass-lg);
  overflow: hidden;
}