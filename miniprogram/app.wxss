page {
  --primary: #2f6ff6;
  --primary-deep: #2457e6;
  --primary-light: rgba(47, 111, 246, 0.12);
  --primary-gradient: linear-gradient(135deg, #66a6ff 0%, #2f6ff6 54%, #7c5cff 100%);
  --aqua: #16c7c3;
  --violet: #7c5cff;
  --success: #22c55e;
  --warning: #f59e0b;
  --danger: #ef4444;
  --text-main: #111827;
  --text-secondary: #667085;
  --text-light: #98a2b3;
  --bg-page: linear-gradient(155deg, #f8fbff 0%, #eaf3ff 42%, #f7fbff 72%, #eef3ff 100%);
  --bg-card: rgba(255, 255, 255, 0.72);
  --bg-card-strong: rgba(255, 255, 255, 0.9);
  --border: rgba(255, 255, 255, 0.88);
  --line: rgba(111, 136, 181, 0.16);
  --radius-sm: 16rpx;
  --radius-md: 28rpx;
  --radius-lg: 36rpx;
  --radius-xl: 48rpx;
  --shadow: 0 16rpx 48rpx rgba(47, 111, 246, 0.12);
  --shadow-strong: 0 22rpx 64rpx rgba(47, 111, 246, 0.22);
  background: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: var(--text-main);
  font-variant-numeric: tabular-nums;
}

.container {
  min-height: 100vh;
  padding: 42rpx 32rpx 40rpx;
  box-sizing: border-box;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
  border: 1rpx solid var(--border);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--text-light);
}

.btn-primary {
  background: var(--primary-gradient);
  color: #fff;
  border-radius: 999rpx;
  min-height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: var(--shadow-strong);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-sizing: border-box;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.62);
  color: var(--primary);
  border-radius: 999rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  box-shadow: 0 8rpx 28rpx rgba(47, 111, 246, 0.08);
  box-sizing: border-box;
}

.btn-secondary::after {
  border: none;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  letter-spacing: 0;
}

.section-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}

.input-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--line);
}

.input-row:last-child {
  border-bottom: none;
}

.input-label {
  font-size: 30rpx;
  color: var(--text-main);
  display: flex;
  align-items: center;
}

.input-value {
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 500;
}

.input-placeholder {
  color: var(--text-light);
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.glass-panel {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
}

.page-title,
.page-heading {
  letter-spacing: 0;
}

button {
  margin: 0;
  padding: 0;
}

button::after {
  border: none;
}

input {
  min-height: 44rpx;
}
